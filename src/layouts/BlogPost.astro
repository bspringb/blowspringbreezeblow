---
import { Image } from 'astro:assets';
import { getEntries } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, categories, relatedObjects } = Astro.props;
const kicker = categories && categories.length > 0 ? categories.join(' · ') : 'Essay';
const relatedObjectEntries =
	relatedObjects && relatedObjects.length > 0 ? await getEntries(relatedObjects) : [];
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 400px;
				max-width: calc(100% - 2em);
				margin: 0 auto 2em auto;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 4px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 68ch;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: var(--ink);
			}
			.title {
				margin-bottom: 2em;
				padding: 2em 0 1em 0;
			}
			.kicker {
				font-family: var(--font-sans);
				font-size: 0.85em;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--accent-bright);
				margin: 0 0 0.6em 0;
			}
			.title h1 {
				margin: 0 0 0.6em 0;
				line-height: 1.15;
			}
			.date {
				font-family: var(--font-sans);
				font-size: 0.85em;
				margin-bottom: 0.5em;
				color: var(--ink-dim);
			}
			.last-updated-on {
				font-style: italic;
			}
			.section-heading {
				font-family: var(--font-sans);
				font-size: 0.85em;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--ink-dim);
				margin: 0 0 1em 0;
			}
			.related-objects {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.related-objects li {
				margin-bottom: 0.5em;
			}
			.related-objects a {
				color: var(--ink);
				text-decoration: underline;
			}
			.related-objects a:hover {
				color: var(--accent-bright);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<p class="kicker">{kicker}</p>
						<h1>{title}</h1>
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<hr />
					</div>
					<slot />
					{
						relatedObjectEntries.length > 0 && (
							<>
								<hr />
								<p class="section-heading">관련 객체</p>
								<ul class="related-objects">
									{relatedObjectEntries.map((related) => (
										<li>
											<a href={`${import.meta.env.BASE_URL}objects/${related.id}/`}>
												{related.data.title}
											</a>
											<span> ({related.data.type})</span>
										</li>
									))}
								</ul>
							</>
						)
					}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
