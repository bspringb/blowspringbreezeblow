---
import { getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
	films: CollectionEntry<'films'>[];
}

const { films } = Astro.props;
const withDirectors = await Promise.all(
	films.map(async (film) => ({ film, director: await getEntry(film.data.director) })),
);
---

<ul class="film-list">
	{
		withDirectors.map(({ film, director }) => (
			<li>
				<a href={`${import.meta.env.BASE_URL}films/${film.id}/`}>
					<p class="meta">
						{director?.data.title}
						{' · '}
						{film.data.year}
						{film.data.rating !== undefined && <> · {film.data.rating.toFixed(1)} / 5</>}
					</p>
					<h3 class="title">{film.data.title}</h3>
					{film.data.description && <p class="description">{film.data.description}</p>}
				</a>
			</li>
		))
	}
</ul>

<style>
	.film-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.film-list li {
		padding: 1.2em 0;
		border-bottom: 1px solid var(--rule);
	}
	.film-list a {
		display: block;
		text-decoration: none;
		color: inherit;
	}
	.meta {
		font-family: var(--font-sans);
		font-size: 0.85em;
		color: var(--ink-dim);
		margin: 0 0 0.3em 0;
	}
	.title {
		margin: 0 0 0.3em 0;
	}
	.film-list a:hover .title {
		color: var(--accent-bright);
	}
	.description {
		font-family: var(--font-serif);
		color: var(--ink-dim);
		margin: 0;
	}
</style>
